{
  "manifest_version": 3,
  "name": "YouTube Shorts Cooldown",
  "version": "1.0.0",
  "description": "YouTube Shortsを5分間視聴した後、30分間Shorts動画を見れなくする。",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "YouTube Shorts Cooldown",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
